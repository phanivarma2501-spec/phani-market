# ─── Polymarket Bot — Environment Variables ───────────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# Required: Anthropic API key (for Claude reasoning engine)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Telegram alerts (highly recommended)
# Create a bot via @BotFather, get your chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phase control — NEVER change LIVE_TRADING_ENABLED to True in Phase 1
PHASE=1
PAPER_TRADING=True
LIVE_TRADING_ENABLED=False

# Strategy tuning (optional — defaults are sensible)
# MIN_EDGE_TO_FLAG=0.06       # Flag signals with edge >= 6%
# HIGH_CONFIDENCE_EDGE=0.12   # Strong signal threshold
# REASONING_CONFIDENCE_MIN=0.65

# Domain focus (comma-separated: crypto, politics, economics)
# FOCUS_DOMAINS=["crypto","politics","economics"]
